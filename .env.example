# SentinelPhish Environment Configuration
# Copy this file to .env.local and fill in your actual API keys
# Never commit .env.local to version control

# ============================================
# AI API Configuration (Required)
# ============================================
# Google Gemini API Key or Google AI API Key
# Get one from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Clerk Authentication (Required)
# ============================================
# Clerk Publishable Key (starts with pk_test_ or pk_live_)
# Get from: https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Clerk Secret Key (starts with sk_test_ or sk_live_)
# Get from: https://dashboard.clerk.com/last-active?path=api-keys
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ============================================
# Convex Backend (Optional)
# ============================================
# Convex Deployment URL
# Get from: https://dashboard.convex.dev
# Leave empty if you don't want to use Convex features
NEXT_PUBLIC_CONVEX_URL=your_convex_url_here

# ============================================
# Optional: Base URL for API Calls
# ============================================
# Set this if deploying to a specific domain
# Defaults to window.location.origin if not set
NEXT_PUBLIC_BASE_URL=http://localhost:3000
